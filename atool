# HTTP requests
# ============================================================

_opener = None

def _init_proxy(proxy_url):
    """Initialize proxy, supports http/https/socks5"""
    global _opener
    if not proxy_url:
        return
    if proxy_url.startswith("socks5://") or proxy_url.startswith("socks5h://"):
        # socks5 via env var to avoid polluting the global socket module
        os.environ["ALL_PROXY"] = proxy_url
    else:
        handler = urllib.request.ProxyHandler({"http": proxy_url, "https": proxy_url})
        _opener = urllib.request.build_opener(handler)


_RETRYABLE_CODES = {429, 500, 502, 503}


def _http_post_stream(url, headers, payload, retries=2):
    """Send POST request and return raw response for SSE streaming."""
    data = json.dumps(payload).encode()
    open_fn = _opener.open if _opener else urllib.request.urlopen
    for attempt in range(retries + 1):
        req = urllib.request.Request(url, data=data, headers=headers)
        try:
            return open_fn(req, timeout=300)
        except urllib.error.HTTPError as e:
            if e.code in _RETRYABLE_CODES and attempt < retries:
                wait = 2 ** attempt
                print(f"\033[33mAPI returned {e.code}, retrying in {wait}s...\033[0m")
                time.sleep(wait)
                continue
            raise
        except (urllib.error.URLError, OSError) as e:
            if attempt < retries:
                wait = 2 ** attempt
                print(f"\033[33mNetwork error: {e}, retrying in {wait}s...\033[0m")
                time.sleep(wait)
                continue
            raise


def _iter_sse_events(resp):
    """Yield parsed SSE data objects from an HTTP response stream."""
    data_buf = []
    for raw_line in resp:
        line = raw_line.decode("utf-8", errors="replace").rstrip("\r\n")
        if line.startswith("data: "):
            data_buf.append(line[6:])
        elif not line:
            if data_buf:
                payload = "\n".join(data_buf)
                data_buf.clear()
                if payload == "[DONE]":
                    return
                try:
                    yield json.loads(payload)
                except json.JSONDecodeError:
                    pass
    if data_buf:
        payload = "\n".join(data_buf)
        if payload != "[DONE]":
            try:
                yield json.loads(payload)
            except json.JSONDecodeError:
                pass


def _bearer_headers(api_key):
    return {"Content-Type": "application/json", "Authorization": f"Bearer {api_key}", "User-Agent": f"atool/{VERSION}"}


def _anthropic_headers(api_key, auth_type="key"):
    headers = {"Content-Type": "application/json", "anthropic-version": "2023-06-01", "User-Agent": f"atool/{VERSION}"}
    if auth_type == "oauth":
        headers["Authorization"] = f"Bearer {api_key}"
    else:
        headers["x-api-key"] = api_key
    return headers


