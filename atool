def _openai_init(system, task):
    return [{"role": "system", "content": system}, {"role": "user", "content": task}]


def _openai_request(state, config):
    base = config["api_url"].rstrip("/")
    url = base if base.endswith("/chat/completions") else base + "/chat/completions"
    data = _http_post(url, _bearer_headers(config["api_key"]),
                      {"model": config["model"], "messages": state, "tools": TOOLS,
                       "stream": False})

    if "error" in data:
        err = data["error"]
        msg = err.get("message", err) if isinstance(err, dict) else err
        raise RuntimeError(f"API error: {msg}")
    if not data.get("choices"):
        raise RuntimeError(f"Unexpected API response format: {json.dumps(data, ensure_ascii=False)[:200]}")
    choice = data["choices"][0]
    msg = choice["message"]
    # Keep only standard fields, filter out non-standard fields like reasoning_content
    clean = {"role": msg["role"], "content": msg.get("content")}
    if msg.get("tool_calls"):
        clean["tool_calls"] = msg["tool_calls"]
    state.append(clean)

    tool_calls = []
    for tc in (msg.get("tool_calls") or []):
        try:
            tool_calls.append({"id": tc["id"], "name": tc["function"]["name"],
                               "args": json.loads(tc["function"]["arguments"])})
        except (KeyError, json.JSONDecodeError, TypeError) as e:
            tool_calls.append({"id": tc.get("id", "unknown"), "name": "__parse_error__",
                               "args": {}, "_error": f"Failed to parse tool call: {e}"})
    finish = choice.get("finish_reason")
    if finish == "length":
        print("\033[33mWarning: model output truncated (token limit reached)\033[0m")
    return {"content": msg.get("content"), "tool_calls": tool_calls}


def _openai_add_tool_result(state, call_id, result):
    if isinstance(result, dict) and result.get("_image"):
        content = f"[Image: data:{result['media_type']};base64,{result['data']}]"
    else:
        content = result
    state.append({"role": "tool", "tool_call_id": call_id, "content": content})


