def _load_oauth_token(provider):
    """Load OAuth token from CLI tool credential files"""
    try:
        if provider == "claude":
            path = os.path.expanduser("~/.claude/.credentials.json")
        elif provider == "codex":
            path = os.path.expanduser("~/.codex/auth.json")
        else:
            return None
        if not os.path.exists(path):
            return None
        if not _is_owner(path):
            print(f"\033[31mWarning: {path} has unexpected owner, ignored\033[0m")
            return None
        with open(path) as f:
            data = json.load(f)
        if provider == "claude":
            return data.get("claudeAiOauth", {}).get("accessToken")
        return data.get("OPENAI_API_KEY")
    except Exception:
        return None


