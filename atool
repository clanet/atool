# Main loop
# ============================================================

def _format_tool_args(name, args, meta=None):
    if name == "execute_command":
        base = args["command"]
        extras = []
        if args.get("cwd"):
            extras.append(f"cwd={args['cwd']}")
        if args.get("timeout_sec"):
            extras.append(f"timeout={args['timeout_sec']}s")
        if _as_bool(args.get("shell"), False):
            extras.append("shell")
        if extras:
            base = f"{base} ({', '.join(extras)})"
    elif name == "list_dir":
        base = args["path"]
    elif name == "search_text":
        base = f"{args['path']} :: {args['query']}"
    elif name == "patch_file":
        edits = args.get("edits", [])
        base = f"{args['path']} ({len(edits)} edit(s))"
    elif name in ("read_file", "write_file", "read_image"):
        base = args["path"]
    else:
        base = json.dumps(args, ensure_ascii=False)
    brief = _tool_metadata_brief(meta)
    if brief:
        return f"{base} [{brief}]"
    return base


def _print_result(name, result):
    # Common error handling for non-command tools
    if name != "execute_command" and "error" in result:
        print(f"\033[31m  Error: {result['error']}\033[0m")
        return
    if name == "execute_command":
        if result["stdout"]:
            print(result["stdout"], end="")
        if result["stderr"]:
            print(f"\033[31m{result['stderr']}\033[0m", end="")
        if result["returncode"] != 0:
            print(f"\033[31m  Exit code: {result['returncode']}\033[0m")
    elif name == "list_dir":
        if not result.get("entries"):
            print("  Directory is empty")
        else:
            for entry in result["entries"][:20]:
                size = "" if entry.get("size") is None else f" ({entry['size']}B)"
                print(f"{entry['type']:>7}  {entry['name']}{size}")
            if result.get("truncated"):
                print(f"... ({result['count']} entries total)")
    elif name == "read_file":
        header = f"[lines {result.get('start_line', 1)}-{result.get('end_line', 0)} of {result.get('total_lines', 0)}]"
        lines = result["content"].splitlines()
        preview = "\n".join(lines[:10])
        if len(lines) > 10:
            preview += f"\n... ({len(lines)} returned lines)"
        print(f"{header}\n{preview}" if preview else header)
    elif name == "search_text":
        if not result.get("matches"):
            print("  No matches found")
        else:
            for match in result["matches"][:10]:
                print(f"{match['path']}:{match['line']}: {match['text']}")
            if result.get("count", 0) > 10:
                print(f"... ({result['count']} matches returned)")
    elif name == "patch_file":
        if result.get("changed"):
            extra = f", backup: {result['backup_path']}" if result.get("backup_path") else ""
            print(f"  Patch successful ({result['applied']} applied match(es) across {result['edits']} edit(s){extra})")
        else:
            print("  Patch completed with no content changes")
    elif name == "write_file":
        status = "created" if result.get("created") else "updated" if result.get("changed") else "unchanged"
        extra = f", backup: {result['backup_path']}" if result.get("backup_path") else ""
        print(f"  Write successful ({status}{extra})")


def main_loop(task, config, auto_yes, continue_ctx=False, force_yes=False, dry_run=False):
    p = PROVIDERS[config["provider"]]
    provider = config["provider"]

    if continue_ctx:
        state = _load_context(provider)
        if state:
            print("\033[36mContinuing previous conversation\033[0m")
            # Append new task as user message
            if provider == "claude":
                state["messages"].append({"role": "user", "content": task})
            elif provider in ("openai", "codex"):
                state.append({"role": "user", "content": task})
        else:
            print("\033[33mNo previous context found, starting new conversation\033[0m")
            state = p["init"](_build_system_prompt(config.get("language")), task)
    else:
        state = p["init"](_build_system_prompt(config.get("language")), task)

    iterations = 0
    total_usage = {"input_tokens": 0, "output_tokens": 0}
    while True:
        iterations += 1
        if iterations > MAX_ITERATIONS:
            print("\033[33mMax iteration limit reached, stopping\033[0m")
            _save_context(state, provider)
            break

        _compact_context(state, provider)

        try:
            parsed = p["request"](state, config)
        except urllib.error.HTTPError as e:
            try:
                body = e.read().decode()
            except Exception:
                body = ""
            print(f"\033[31mAPI request failed ({e.code}): {body[:200]}\033[0m")
            break
        except urllib.error.URLError as e:
            print(f"\033[31mCannot connect to API: {e.reason}\033[0m")
            break
        except Exception as e:
            print(f"\033[31mAPI call error: {e}\033[0m")
            break

        # Accumulate token usage
        usage = parsed.get("usage")
        if usage:
            total_usage["input_tokens"] += usage.get("input_tokens") or usage.get("prompt_tokens") or 0
            total_usage["output_tokens"] += usage.get("output_tokens") or usage.get("completion_tokens") or 0

        # Content already printed via streaming

        if not parsed["tool_calls"]:
            _save_context(state, provider)
            break

        for tc in parsed["tool_calls"]:
            try:
                name, args = tc["name"], tc["args"]
                # Tool call that failed at parse stage
                if name == "__parse_error__":
                    result_str = json.dumps({"error": tc["_error"]}, ensure_ascii=False)
                    print(f"\n\033[31m{tc['_error']}\033[0m")
                    p["add_tool_result"](state, tc["id"], result_str)
                    continue

                meta = _tool_metadata(name, args) if name in ("execute_command", "patch_file", "write_file") else None
                print(f"\n\033[36m→ {name}: {_format_tool_args(name, args, meta)}\033[0m")

                if dry_run:
                    result_str = json.dumps({"dry_run": True, "skipped": "Dry-run mode: tool not executed"}, ensure_ascii=False)
                    print("\033[33m  [dry-run] Skipped\033[0m")
                    p["add_tool_result"](state, tc["id"], result_str)
                    continue

                if name not in TOOL_HANDLERS:
                    result_str = json.dumps({"error": f"Unknown tool: {name}"}, ensure_ascii=False)
                    print(f"\033[31m  Unknown tool: {name}\033[0m")
                elif confirm_action(name, args, auto_yes, config.get("confirm_default", "y"), force_yes, meta):
                    result = TOOL_HANDLERS[name](args)
                    if isinstance(result, dict) and result.get("_image") and "error" not in result:
                        print(f"  \033[32mImage loaded ({len(result['data']) * 3 // 4 // 1024}KB)\033[0m")
                        p["add_tool_result"](state, tc["id"], result)
                        continue
                    _print_result(name, result)
                    result_str = json.dumps(_truncate_result(result), ensure_ascii=False)
                else:
                    result_str = json.dumps({"skipped": "User declined execution"}, ensure_ascii=False)
                    print("\033[33m  Skipped\033[0m")
            except Exception as e:
                result_str = json.dumps({"error": f"Tool execution error: {e}"}, ensure_ascii=False)
                print(f"\033[31m  Tool execution error: {e}\033[0m")

            p["add_tool_result"](state, tc["id"], result_str)

        _save_context(state, provider)

    _print_usage_summary(total_usage)


