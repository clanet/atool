MAX_LINES = 20
MAX_CHARS = 8000
MAX_ITERATIONS = 50
MAX_CONTEXT_CHARS = 200000  # Context char limit, roughly ~60K tokens
PATCH_PREVIEW_MAX_LINES = 30
PATCH_PREVIEW_MAX_CHARS = 2500
SEARCH_TEXT_MAX_MATCHES = 100
SEARCH_SKIP_DIRS = {".git", "node_modules", "__pycache__", ".hg", ".svn", ".tox", "venv", ".venv"}
LIST_DIR_MAX_ENTRIES = 200
DEFAULT_COMMAND_TIMEOUT = 300


def _as_bool(value, default=False):
    if isinstance(value, bool):
        return value
    if isinstance(value, str):
        val = value.strip().lower()
        if val in ("true", "1", "yes", "y", "on"):
            return True
        if val in ("false", "0", "no", "n", "off", ""):
            return False
    return default


def _truncate(text):
    """Truncate long text: keep first 20 + last 20 lines, cap total chars"""
    # Line truncation first
    lines = text.splitlines()
    if len(lines) > MAX_LINES * 2:
        head = "\n".join(lines[:MAX_LINES])
        tail = "\n".join(lines[-MAX_LINES:])
        text = f"{head}\n\n... (omitted {len(lines) - MAX_LINES * 2} middle lines, {len(lines)} total) ...\n\n{tail}"
    # Char truncation (fallback)
    if len(text) > MAX_CHARS:
        total = len(text)
        marker = f"\n\n... (omitted middle section, {total} chars total) ...\n\n"
        half = (MAX_CHARS - len(marker)) // 2
        text = f"{text[:half]}{marker}{text[-half:]}"
    return text


def _truncate_preview(text):
    """Keep preview blocks short enough for confirmation prompts."""
    lines = text.splitlines()
    if len(lines) > PATCH_PREVIEW_MAX_LINES:
        shown = "\n".join(lines[:PATCH_PREVIEW_MAX_LINES])
        text = f"{shown}\n... (preview truncated, {len(lines)} lines total)"
    if len(text) > PATCH_PREVIEW_MAX_CHARS:
        text = text[:PATCH_PREVIEW_MAX_CHARS] + "\n... (preview truncated)"
    return text


def _indent_block(text, prefix="    "):
    return "\n".join(prefix + line for line in text.splitlines())


def _read_text_file(path):
    with open(path, "r", encoding="utf-8", errors="surrogateescape") as f:
        return f.read()


def _coerce_int(value, default, minimum=None, maximum=None):
    if value is None or value == "":
        return default
    try:
        num = int(value)
    except (ValueError, TypeError):
        return default
    if minimum is not None and num < minimum:
        num = minimum
    if maximum is not None and num > maximum:
        num = maximum
    return num


def _sanitize_str(text):
    """Replace surrogate escapes with the replacement character for safe JSON encoding"""
    return text.encode("utf-8", errors="replace").decode("utf-8")


def _truncate_result(result):
    """Truncate tool result for sending to AI, original result unchanged"""
    truncated = {}
    for k, v in result.items():
        if isinstance(v, str):
            truncated[k] = _truncate(_sanitize_str(v))
        else:
            truncated[k] = v
    return truncated


def _read_stream(stream, parts, max_chars):
    """Read stream line by line, stop when exceeding max_chars, return whether truncated"""
    total = 0
    for line in stream:
        if total + len(line) > max_chars:
            return True
        parts.append(line)
        total += len(line)
    return False


def _kill_proc(proc):
    """Kill process and its children"""
    try:
        if IS_WINDOWS:
            subprocess.call(["taskkill", "/F", "/T", "/PID", str(proc.pid)],
                            stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
        else:
            os.killpg(proc.pid, signal.SIGKILL)
    except OSError:
        pass


def execute_command(command, cwd=None, timeout_sec=None, shell=None):
    proc = None
    stdout_parts, stderr_parts = [], []
    try:
        if not isinstance(command, str) or not command.strip():
            return {"stdout": "", "stderr": "Command must be a non-empty string", "returncode": -1}
        workdir = _safe_realpath(cwd) if cwd else None
        if workdir and not os.path.isdir(workdir):
            return {"stdout": "", "stderr": f"Working directory does not exist: {workdir}", "returncode": -1}
        use_shell = _as_bool(shell, False)
        timeout = _coerce_int(timeout_sec, DEFAULT_COMMAND_TIMEOUT, minimum=1, maximum=3600)

        popen_shell = use_shell
        if IS_WINDOWS:
            if use_shell:
                # Run via PowerShell directly to avoid cmd.exe mangling pipes and quotes
                popen_args = ["powershell", "-NoProfile", "-NonInteractive", "-Command", command]
                popen_shell = False
            else:
                popen_args = shlex.split(command, posix=False)
        else:
            popen_args = command if use_shell else shlex.split(command)

        proc = subprocess.Popen(
            popen_args,
            shell=popen_shell,
            cwd=workdir,
            stdout=subprocess.PIPE,
            stderr=subprocess.PIPE,
            text=True,
            encoding="utf-8",
            errors="replace",
            start_new_session=not IS_WINDOWS,
        )
        truncated = [False, False]  # [stdout, stderr]
        thread_errors = []

        # Read stdout/stderr in parallel threads to avoid pipe buffer deadlock
        def read_out():
            try:
                truncated[0] = _read_stream(proc.stdout, stdout_parts, MAX_CHARS)
            except Exception as e:
                thread_errors.append(f"stdout read error: {e}")
        def read_err():
            try:
                truncated[1] = _read_stream(proc.stderr, stderr_parts, MAX_CHARS)
            except Exception as e:
                thread_errors.append(f"stderr read error: {e}")

        t1 = threading.Thread(target=read_out, daemon=True)
        t2 = threading.Thread(target=read_err, daemon=True)
        t1.start()
        t2.start()
        # Use short join intervals so KeyboardInterrupt can be caught promptly
        deadline = time.monotonic() + timeout
        while t1.is_alive() and time.monotonic() < deadline:
            t1.join(timeout=0.5)
        while t2.is_alive() and time.monotonic() < deadline:
            t2.join(timeout=0.5)
        timed_out = (t1.is_alive() or t2.is_alive()) and time.monotonic() >= deadline

        # Force kill if still writing after truncation
        if truncated[0] or truncated[1] or timed_out:
            _kill_proc(proc)
        try:
            proc.wait(timeout=10)
        except subprocess.TimeoutExpired:
            _kill_proc(proc)
            proc.wait()
            timed_out = True

        stdout = "".join(stdout_parts)
        stderr = "".join(stderr_parts)
        if thread_errors:
            details = "; ".join(thread_errors)
            stderr = details if not stderr else stderr + "\n" + details
            return {"stdout": stdout, "stderr": stderr, "returncode": -1}
        if timed_out:
            stderr = f"Command timed out ({timeout}s)" if not stderr else stderr + f"\nCommand timed out ({timeout}s)"
            return {"stdout": stdout, "stderr": stderr, "returncode": -1}
        if truncated[0]:
            stdout += f"\n... (output exceeded {MAX_CHARS} chars, truncated)"
        if truncated[1]:
            stderr += f"\n... (output exceeded {MAX_CHARS} chars, truncated)"
        return {"stdout": stdout, "stderr": stderr, "returncode": proc.returncode}
    except KeyboardInterrupt:
        if proc is not None:
            _kill_proc(proc)
            proc.wait()
        return {"stdout": "".join(stdout_parts), "stderr": "Interrupted by user (Ctrl+C)", "returncode": -1}
    except Exception as e:
        return {"stdout": "", "stderr": str(e), "returncode": -1}
    finally:
        if proc is not None:
            for stream in (proc.stdout, proc.stderr):
                try:
                    if stream:
                        stream.close()
                except Exception:
                    pass


def read_file(path, start_line=None, max_lines=None):
    try:
        path = _safe_realpath(path)
        # Block reading config file containing API keys
        if path == CONF_REALPATH:
            return {"error": "Security restriction: cannot read config file (contains API Key)"}
        start = _coerce_int(start_line, 1, minimum=1)
        limit = _coerce_int(max_lines, None, minimum=1) if max_lines not in (None, "") else None
        total_lines = 0
        captured = []
        with open(path, "r", encoding="utf-8", errors="replace") as f:
            for line in f:
                total_lines += 1
                if total_lines < start:
                    continue
                if limit is None or len(captured) < limit:
                    captured.append(line)

        display_start = start if total_lines >= start else (total_lines + 1 if total_lines else 1)
        end_line = display_start + len(captured) - 1 if captured else display_start - 1
        return {
            "content": "".join(captured),
            "start_line": display_start,
            "end_line": end_line,
            "total_lines": total_lines,
            "truncated": total_lines > end_line,
        }
    except Exception as e:
        return {"error": str(e)}


def list_dir(path, max_entries=None, show_hidden=False):
    try:
        path = _safe_realpath(path)
        if not os.path.isdir(path):
            return {"error": "Path is not a directory"}
        limit = _coerce_int(max_entries, 50, minimum=1, maximum=LIST_DIR_MAX_ENTRIES)
        include_hidden = _as_bool(show_hidden, False)

        entries = []
        scan_limit = limit * 10  # Cap scanning to avoid memory issues on huge directories
        scanned = 0
        with os.scandir(path) as it:
            for entry in it:
                if not include_hidden and entry.name.startswith("."):
                    continue
                scanned += 1
                if scanned > scan_limit:
                    break
                try:
                    stat = entry.stat(follow_symlinks=False)
                except OSError:
                    stat = None
                if entry.is_symlink():
                    kind = "symlink"
                elif entry.is_dir(follow_symlinks=False):
                    kind = "dir"
                elif entry.is_file(follow_symlinks=False):
                    kind = "file"
                else:
                    kind = "other"
                entries.append({
                    "name": entry.name,
                    "path": entry.path,
                    "type": kind,
                    "size": stat.st_size if stat else None,
                })

        scan_truncated = scanned > scan_limit
        entries.sort(key=lambda item: (item["type"] != "dir", item["name"].lower(), item["name"]))
        return {
            "path": path,
            "entries": entries[:limit],
            "count": len(entries),
            "truncated": len(entries) > limit or scan_truncated,
        }
    except Exception as e:
        return {"error": str(e)}


def _is_binary_file(path):
    try:
        with open(path, "rb") as f:
            return b"\0" in f.read(4096)
    except Exception:
        return True


def search_text(path, query, max_matches=None, case_sensitive=False, regex=False):
    try:
        path = _safe_realpath(path)
        if path == CONF_REALPATH:
            return {"error": "Security restriction: cannot search config file (contains API Key)"}
        if not os.path.exists(path):
            return {"error": "Path does not exist"}
        if not isinstance(query, str) or not query:
            return {"error": "query must be a non-empty string"}

        limit = _coerce_int(max_matches, 20, minimum=1, maximum=SEARCH_TEXT_MAX_MATCHES)
        sensitive = _as_bool(case_sensitive, False)
        use_regex = _as_bool(regex, False)
        if use_regex:
            flags = 0 if sensitive else re.IGNORECASE
            try:
                pattern = re.compile(query, flags)
            except re.error as e:
                return {"error": f"Invalid regex: {e}"}
        needle = None if use_regex else (query if sensitive else query.lower())
        matches = []
        files_scanned = 0

        def iter_targets():
            if os.path.isdir(path):
                for root, dirs, files in os.walk(path):
                    dirs[:] = [d for d in dirs if d not in SEARCH_SKIP_DIRS]
                    dirs.sort(key=lambda name: name.lower())
                    for name in sorted(files, key=lambda item: item.lower()):
                        file_path = os.path.join(root, name)
                        real_file_path = _safe_realpath(file_path)
                        if real_file_path == CONF_REALPATH:
                            continue
                        yield real_file_path
            else:
                yield path

        for target in iter_targets():
            if len(matches) >= limit:
                break
            if _is_binary_file(target):
                continue
            try:
                f = open(target, "r", encoding="utf-8", errors="replace")
            except Exception:
                continue
            try:
                files_scanned += 1
                for line_no, line in enumerate(f, start=1):
                    text = line.rstrip("\r\n")
                    if use_regex:
                        matched = pattern.search(text)
                    else:
                        haystack = text if sensitive else text.lower()
                        matched = needle in haystack
                    if matched:
                        matches.append({"path": target, "line": line_no, "text": text})
                        if len(matches) >= limit:
                            break
            finally:
                f.close()

        return {
            "matches": matches,
            "count": len(matches),
            "limit": limit,
            "files_scanned": files_scanned,
            "truncated": len(matches) >= limit,
        }
    except Exception as e:
        return {"error": str(e)}


_IMAGE_EXTENSIONS = {".png": "image/png", ".jpg": "image/jpeg", ".jpeg": "image/jpeg",
                     ".gif": "image/gif", ".webp": "image/webp", ".bmp": "image/bmp"}
MAX_IMAGE_SIZE = 20 * 1024 * 1024  # 20MB


def read_image(path):
    try:
        path = _safe_realpath(path)
        ext = os.path.splitext(path)[1].lower()
        media_type = _IMAGE_EXTENSIONS.get(ext)
        if not media_type:
            return {"error": f"Unsupported image format: {ext}"}
        if os.path.getsize(path) > MAX_IMAGE_SIZE:
            return {"error": "Image too large (>20MB)"}
        with open(path, "rb") as f:
            data = base64.b64encode(f.read()).decode("ascii")
        return {"_image": True, "media_type": media_type, "data": data}
    except Exception as e:
        return {"error": str(e)}


def _safe_realpath(path):
    if path is None:
        return ""
    try:
        return os.path.realpath(os.path.expanduser(path))
    except Exception:
        return str(path)


MAX_BACKUPS = 5


def _make_backup(path):
    timestamp = time.strftime("%Y%m%d-%H%M%S")
    backup_path = f"{path}.atool.bak.{timestamp}-{os.getpid()}-{time.time_ns() % 1000000:06d}"
    shutil.copy2(path, backup_path)
    # Clean up old backups, keep only the most recent MAX_BACKUPS
    try:
        parent = os.path.dirname(path) or "."
        base = os.path.basename(path) + ".atool.bak."
        backup_names = [f for f in os.listdir(parent) if f.startswith(base)]
        if len(backup_names) > MAX_BACKUPS:
            backup_names.sort(reverse=True)
            for old_name in backup_names[MAX_BACKUPS:]:
                os.unlink(os.path.join(parent, old_name))
    except OSError:
        pass
    return backup_path


def _preserve_file_metadata(src_path, dst_path):
    try:
        st = os.stat(src_path, follow_symlinks=False)
    except OSError:
        return
    try:
        os.chmod(dst_path, st.st_mode & 0o777)
    except OSError:
        pass


def _atomic_write_text(path, content):
    directory = os.path.dirname(path) or "."
    os.makedirs(directory, exist_ok=True, mode=0o755)
    fd, tmp_path = tempfile.mkstemp(prefix=".atool-tmp-", dir=directory, text=True)
    try:
        with os.fdopen(fd, "w", encoding="utf-8", errors="surrogateescape") as f:
            f.write(content)
        _preserve_file_metadata(path, tmp_path)
        os.replace(tmp_path, path)
    except Exception:
        try:
            os.unlink(tmp_path)
        except OSError:
            pass
        raise


def _apply_patch_edits(content, edits):
    updated = content
    applied = 0
    for idx, edit in enumerate(edits, start=1):
        if not isinstance(edit, dict):
            return {"error": f"Edit {idx}: expected an object"}
        action = str(edit.get("action", "")).strip().lower()
        target_text = edit.get("target_text")
        new_text = edit.get("new_text")
        all_matches = _as_bool(edit.get("all_matches", edit.get("replace_all")), False)

        if action not in ("replace", "insert_before", "insert_after"):
            return {"error": f"Edit {idx}: action must be replace, insert_before, or insert_after"}
        if not isinstance(target_text, str) or not isinstance(new_text, str):
            return {"error": f"Edit {idx}: target_text and new_text must be strings"}
        if not target_text:
            return {"error": f"Edit {idx}: target_text must not be empty"}

        matches = updated.count(target_text)
        if matches == 0:
            return {"error": f"Edit {idx}: target text not found"}
        if all_matches:
            count = matches
        else:
            if matches != 1:
                return {"error": f"Edit {idx}: target text matched {matches} times; provide a more specific snippet or set all_matches=true"}
            count = 1

        if action == "replace":
            updated = updated.replace(target_text, new_text, count)
        elif action == "insert_before":
            updated = updated.replace(target_text, new_text + target_text, count)
        else:
            updated = updated.replace(target_text, target_text + new_text, count)
        applied += count

    return {"content": updated, "applied": applied}


def _patch_preview(path, edits):
    try:
        path = _safe_realpath(path)
        original = _read_text_file(path)
    except Exception as e:
        return {"error": str(e)}

    applied = _apply_patch_edits(original, edits)
    if "error" in applied:
        return applied

    updated = applied["content"]
    if updated == original:
        return {"preview": "No content changes"}

    diff_lines = list(difflib.unified_diff(
        original.splitlines(),
        updated.splitlines(),
        fromfile=path,
        tofile=path,
        lineterm="",
        n=2,
    ))
    if not diff_lines:
        return {"preview": "No content changes"}
    return {"preview": _truncate_preview("\n".join(diff_lines)), "applied": applied["applied"]}


def write_file(path, content):
    try:
        path = _safe_realpath(path)
        if path == CONF_REALPATH:
            return {"error": "Security restriction: cannot overwrite config file through model tools"}
        existed = os.path.exists(path)
        previous = _read_text_file(path) if existed else None
        changed = (not existed) or previous != content
        backup_path = ""
        if changed and existed:
            backup_path = _make_backup(path)
        if changed:
            _atomic_write_text(path, content)
        return {"success": True, "changed": changed, "created": not existed, "backup_path": backup_path}
    except Exception as e:
        return {"error": str(e)}


def patch_file(path, edits):
    try:
        path = _safe_realpath(path)
        if path == CONF_REALPATH:
            return {"error": "Security restriction: cannot modify config file through model tools"}
        if not os.path.exists(path):
            return {"error": "File does not exist; use write_file to create a new file"}
        content = _read_text_file(path)

        applied = _apply_patch_edits(content, edits)
        if "error" in applied:
            return applied
        updated = applied["content"]

        changed = updated != content
        backup_path = ""
        if changed:
            backup_path = _make_backup(path)
            _atomic_write_text(path, updated)
        return {"success": True, "changed": changed, "edits": len(edits), "applied": applied["applied"], "backup_path": backup_path}
    except Exception as e:
        return {"error": str(e)}


TOOL_HANDLERS = {
    "execute_command": lambda a: execute_command(a["command"], a.get("cwd"), a.get("timeout_sec"), a.get("shell")),
    "list_dir": lambda a: list_dir(a["path"], a.get("max_entries"), a.get("show_hidden", False)),
    "read_file": lambda a: read_file(a["path"], a.get("start_line"), a.get("max_lines")),
    "search_text": lambda a: search_text(a["path"], a["query"], a.get("max_matches"), a.get("case_sensitive", False), a.get("regex", False)),
    "patch_file": lambda a: patch_file(a["path"], a["edits"]),
    "write_file": lambda a: write_file(a["path"], a["content"]),
    "read_image": lambda a: read_image(a["path"]),
}


