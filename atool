MAX_LINES = 20
MAX_CHARS = 8000
MAX_ITERATIONS = 50
MAX_CONTEXT_CHARS = 200000  # Context char limit, roughly ~60K tokens


def _truncate(text):
    """Truncate long text: keep first 20 + last 20 lines, cap total chars"""
    # Line truncation first
    lines = text.splitlines()
    if len(lines) > MAX_LINES * 2:
        head = "\n".join(lines[:MAX_LINES])
        tail = "\n".join(lines[-MAX_LINES:])
        text = f"{head}\n\n... (omitted {len(lines) - MAX_LINES * 2} middle lines, {len(lines)} total) ...\n\n{tail}"
    # Char truncation (fallback)
    if len(text) > MAX_CHARS:
        total = len(text)
        marker = f"\n\n... (omitted middle section, {total} chars total) ...\n\n"
        half = (MAX_CHARS - len(marker)) // 2
        text = f"{text[:half]}{marker}{text[-half:]}"
    return text


def _truncate_result(result):
    """Truncate tool result for sending to AI, original result unchanged"""
    truncated = {}
    for k, v in result.items():
        truncated[k] = _truncate(v) if isinstance(v, str) else v
    return truncated


def _read_stream(stream, parts, max_chars):
    """Read stream line by line, stop when exceeding max_chars, return whether truncated"""
    total = 0
    for line in stream:
        if total + len(line) > max_chars:
            return True
        parts.append(line)
        total += len(line)
    return False


def _kill_proc(proc):
    """Kill process and its children"""
    try:
        if IS_WINDOWS:
            subprocess.call(["taskkill", "/F", "/T", "/PID", str(proc.pid)],
                            stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
        else:
            proc.kill()
    except OSError:
        pass


def execute_command(command):
    try:
        if IS_WINDOWS:
            # Run via PowerShell directly to avoid cmd.exe mangling pipes and quotes
            proc = subprocess.Popen(
                ["powershell", "-NoProfile", "-NonInteractive", "-Command", command],
                stdout=subprocess.PIPE, stderr=subprocess.PIPE, text=True)
        else:
            proc = subprocess.Popen(command, shell=True,
                stdout=subprocess.PIPE, stderr=subprocess.PIPE, text=True)
        stdout_parts, stderr_parts = [], []
        truncated = [False, False]  # [stdout, stderr]

        # Read stdout/stderr in parallel threads to avoid pipe buffer deadlock
        def read_out():
            truncated[0] = _read_stream(proc.stdout, stdout_parts, MAX_CHARS)
        def read_err():
            truncated[1] = _read_stream(proc.stderr, stderr_parts, MAX_CHARS)

        t1 = threading.Thread(target=read_out, daemon=True)
        t2 = threading.Thread(target=read_err, daemon=True)
        t1.start()
        t2.start()
        # Use short join intervals so KeyboardInterrupt can be caught promptly
        deadline = time.monotonic() + 300
        while t1.is_alive() and time.monotonic() < deadline:
            t1.join(timeout=0.5)
        remaining = max(0, deadline - time.monotonic())
        while t2.is_alive() and time.monotonic() < deadline:
            t2.join(timeout=0.5)

        # Force kill if still writing after truncation
        if truncated[0] or truncated[1] or t1.is_alive() or t2.is_alive():
            _kill_proc(proc)
        try:
            proc.wait(timeout=10)
        except subprocess.TimeoutExpired:
            _kill_proc(proc)
            proc.wait()
            return {"stdout": "".join(stdout_parts), "stderr": "Command timed out (300s)", "returncode": -1}

        stdout = "".join(stdout_parts)
        stderr = "".join(stderr_parts)
        if truncated[0]:
            stdout += f"\n... (output exceeded {MAX_CHARS} chars, truncated)"
        if truncated[1]:
            stderr += f"\n... (output exceeded {MAX_CHARS} chars, truncated)"
        return {"stdout": stdout, "stderr": stderr, "returncode": proc.returncode}
    except KeyboardInterrupt:
        _kill_proc(proc)
        proc.wait()
        return {"stdout": "".join(stdout_parts), "stderr": "Interrupted by user (Ctrl+C)", "returncode": -1}
    except Exception as e:
        return {"stdout": "", "stderr": str(e), "returncode": -1}


def read_file(path):
    try:
        path = os.path.realpath(os.path.expanduser(path))
        # Block reading config file containing API keys
        if path == os.path.realpath(CONF_PATH):
            return {"error": "Security restriction: cannot read config file (contains API Key)"}
        with open(path, "r", encoding="utf-8", errors="replace") as f:
            content = f.read()
        return {"content": content}
    except Exception as e:
        return {"error": str(e)}


_IMAGE_EXTENSIONS = {".png": "image/png", ".jpg": "image/jpeg", ".jpeg": "image/jpeg",
                     ".gif": "image/gif", ".webp": "image/webp", ".bmp": "image/bmp"}
MAX_IMAGE_SIZE = 20 * 1024 * 1024  # 20MB


def read_image(path):
    try:
        path = os.path.realpath(os.path.expanduser(path))
        ext = os.path.splitext(path)[1].lower()
        media_type = _IMAGE_EXTENSIONS.get(ext)
        if not media_type:
            return {"error": f"Unsupported image format: {ext}"}
        if os.path.getsize(path) > MAX_IMAGE_SIZE:
            return {"error": "Image too large (>20MB)"}
        with open(path, "rb") as f:
            data = base64.b64encode(f.read()).decode("ascii")
        return {"_image": True, "media_type": media_type, "data": data}
    except Exception as e:
        return {"error": str(e)}


def write_file(path, content):
    try:
        path = os.path.realpath(os.path.expanduser(path))
        os.makedirs(os.path.dirname(path), exist_ok=True, mode=0o755)
        with open(path, "w") as f:
            f.write(content)
        return {"success": True}
    except Exception as e:
        return {"error": str(e)}


TOOL_HANDLERS = {
