def _claude_tools():
    return [{"name": t["function"]["name"], "description": t["function"]["description"],
             "input_schema": t["function"]["parameters"]} for t in TOOLS]


def _claude_init(system, task):
    return {"system": system, "messages": [{"role": "user", "content": task}]}


def _claude_request(state, config):
    base = config["api_url"].rstrip("/")
    url = base if base.endswith("/messages") else base + "/messages"
    resp = _http_post_stream(url, _anthropic_headers(config["api_key"], config.get("auth_type", "key")),
                             {"model": config["model"], "max_tokens": _coerce_int(config.get("max_tokens"), 8192, minimum=1),
                              "system": state["system"], "messages": state["messages"],
                              "tools": _claude_tools(), "stream": True})
    content_blocks = {}  # index -> {type, ...accumulated data}
    usage = {}
    stop_reason = None
    first_text = True
    try:
        for event in _iter_sse_events(resp):
            etype = event.get("type")
            if etype == "message_start":
                msg_usage = event.get("message", {}).get("usage")
                if msg_usage:
                    usage.update(msg_usage)
            elif etype == "content_block_start":
                idx = event["index"]
                block = event["content_block"]
                if block["type"] == "text":
                    content_blocks[idx] = {"type": "text", "text": ""}
                elif block["type"] == "tool_use":
                    content_blocks[idx] = {"type": "tool_use", "id": block["id"],
                                           "name": block["name"], "input_json": ""}
            elif etype == "content_block_delta":
                idx = event["index"]
                delta = event.get("delta", {})
                if delta.get("type") == "text_delta" and idx in content_blocks:
                    text = delta.get("text", "")
                    if first_text:
                        print()
                        first_text = False
                    print(text, end="", flush=True)
                    content_blocks[idx]["text"] += text
                elif delta.get("type") == "input_json_delta" and idx in content_blocks:
                    content_blocks[idx]["input_json"] += delta.get("partial_json", "")
            elif etype == "message_delta":
                d = event.get("delta", {})
                if d.get("stop_reason"):
                    stop_reason = d["stop_reason"]
                if event.get("usage"):
                    usage.update(event["usage"])
        if not first_text:
            print()
    finally:
        resp.close()

    assembled = []
    content = None
    tool_calls = []
    for idx in sorted(content_blocks):
        block = content_blocks[idx]
        if block["type"] == "text":
            assembled.append({"type": "text", "text": block["text"]})
            content = (content or "") + block["text"]
        elif block["type"] == "tool_use":
            try:
                inp = json.loads(block["input_json"]) if block["input_json"] else {}
            except json.JSONDecodeError:
                inp = {}
            assembled.append({"type": "tool_use", "id": block["id"],
                              "name": block["name"], "input": inp})
            tool_calls.append({"id": block["id"], "name": block["name"], "args": inp})

    state["messages"].append({"role": "assistant", "content": assembled})

    if stop_reason == "max_tokens":
        print("\033[33mWarning: model output truncated (token limit reached)\033[0m")
    return {"content": content, "tool_calls": tool_calls, "usage": usage}


def _claude_add_tool_result(state, call_id, result):
    if isinstance(result, dict) and result.get("_image"):
        content = [{"type": "image", "source": {"type": "base64",
                    "media_type": result["media_type"], "data": result["data"]}}]
    else:
        content = result
    result_block = {"type": "tool_result", "tool_use_id": call_id, "content": content}
    msgs = state["messages"]
    # Merge multiple tool_results into the same user message
    if msgs and msgs[-1]["role"] == "user" and isinstance(msgs[-1]["content"], list):
        msgs[-1]["content"].append(result_block)
    else:
        msgs.append({"role": "user", "content": [result_block]})


