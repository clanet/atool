def _openai_init(system, task):
    return [{"role": "system", "content": system}, {"role": "user", "content": task}]


def _openai_request(state, config):
    base = config["api_url"].rstrip("/")
    url = base if base.endswith("/chat/completions") else base + "/chat/completions"
    resp = _http_post_stream(url, _bearer_headers(config["api_key"]),
                             {"model": config["model"], "messages": state, "tools": TOOLS,
                              "stream": True, "stream_options": {"include_usage": True}})
    content_parts = []
    tc_accum = {}  # index -> {id, name, arguments}
    usage = None
    finish_reason = None
    first_text = True
    try:
        for event in _iter_sse_events(resp):
            if event.get("usage"):
                usage = event["usage"]
            choices = event.get("choices", [])
            if not choices:
                continue
            choice = choices[0]
            if choice.get("finish_reason"):
                finish_reason = choice["finish_reason"]
            delta = choice.get("delta", {})
            if delta.get("content"):
                if first_text:
                    print()
                    first_text = False
                print(delta["content"], end="", flush=True)
                content_parts.append(delta["content"])
            for tc_delta in (delta.get("tool_calls") or []):
                idx = tc_delta.get("index", 0)
                if idx not in tc_accum:
                    tc_accum[idx] = {"id": tc_delta.get("id", ""), "name": "", "arguments": ""}
                if tc_delta.get("id"):
                    tc_accum[idx]["id"] = tc_delta["id"]
                fn = tc_delta.get("function", {})
                if fn.get("name"):
                    tc_accum[idx]["name"] = fn["name"]
                if fn.get("arguments"):
                    tc_accum[idx]["arguments"] += fn["arguments"]
        if not first_text:
            print()
    finally:
        resp.close()

    content = "".join(content_parts) or None
    clean = {"role": "assistant", "content": content}
    tool_calls_raw = []
    for idx in sorted(tc_accum):
        tc = tc_accum[idx]
        tool_calls_raw.append({"id": tc["id"], "type": "function",
                                "function": {"name": tc["name"], "arguments": tc["arguments"]}})
    if tool_calls_raw:
        clean["tool_calls"] = tool_calls_raw
    state.append(clean)

    tool_calls = []
    for tc in tool_calls_raw:
        try:
            tool_calls.append({"id": tc["id"], "name": tc["function"]["name"],
                               "args": json.loads(tc["function"]["arguments"])})
        except (KeyError, json.JSONDecodeError, TypeError) as e:
            tool_calls.append({"id": tc.get("id", "unknown"), "name": "__parse_error__",
                               "args": {}, "_error": f"Failed to parse tool call: {e}"})
    if finish_reason == "length":
        print("\033[33mWarning: model output truncated (token limit reached)\033[0m")
    return {"content": content, "tool_calls": tool_calls, "usage": usage}


def _openai_add_tool_result(state, call_id, result):
    if isinstance(result, dict) and result.get("_image"):
        content = f"[Image: data:{result['media_type']};base64,{result['data']}]"
    else:
        content = result
    state.append({"role": "tool", "tool_call_id": call_id, "content": content})


