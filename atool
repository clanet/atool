# Local safeguard: force confirmation for obviously dangerous patterns
DANGEROUS_REGEXES = [re.compile(p) for p in [
    r'\brm\s+.*(-[rf]|--recursive|--force)', r'\brmdir\b', r'\bmkfs\b', r'\bfdisk\b', r'\bdd\s+if=',
    r'\breboot\b', r'\bshutdown\b', r'\bpoweroff\b', r'\bhalt\b',
    r'\bsystemctl\s+(stop|disable)\b', r'\bservice\s+\S+\s+stop\b',
    r'\bkill\b', r'\bkillall\b', r'\bpkill\b',
    r'\bcurl\b.+\|\s*(bash|sh|zsh)\b', r'\bwget\b.+\|\s*(bash|sh|zsh)\b',
    r'>\s*/dev/', r'\bchmod\s+777\b', r'\bchown\b',
]]
DANGEROUS_PATHS = ["/etc/", "/boot/", "/usr/", "/var/", "/sys/", "/proc/", "/root/", "/lib/", "/lib64/", "/bin/", "/sbin/"]
DANGEROUS_HOME_PATHS = [".ssh/", ".bashrc", ".bash_profile", ".profile", ".zshrc", ".gnupg/"]
SENSITIVITY_LEVELS = ("low", "medium", "high")


def _tool_metadata(tool_name, tool_args):
    model_sensitivity = str(tool_args.get("sensitivity", "")).strip().lower()
    sensitivity = model_sensitivity
    if tool_name in ("execute_command", "patch_file", "write_file"):
        if sensitivity not in SENSITIVITY_LEVELS:
            sensitivity = "high"
    else:
        sensitivity = "low"

    host_notes = []
    overwrite_existing = False
    write_path = tool_args.get("path", "") if tool_name == "write_file" else ""
    if write_path and os.path.exists(_safe_realpath(write_path)):
        overwrite_existing = True
        if sensitivity != "high":
            sensitivity = "high"
            host_notes.append("Raised to high because write_file will fully overwrite an existing file")
        else:
            host_notes.append("Full overwrite of an existing file")

    if tool_name in ("patch_file", "write_file"):
        changes_state = True
    elif tool_name == "execute_command":
        changes_state = _as_bool(tool_args.get("changes_state"), sensitivity != "low")
    else:
        changes_state = _as_bool(tool_args.get("changes_state"), False)

    return {
        "model_sensitivity": model_sensitivity if model_sensitivity in SENSITIVITY_LEVELS else "",
        "sensitivity": sensitivity,
        "changes_state": changes_state,
        "reason": str(tool_args.get("reason", "")).strip(),
        "verify": str(tool_args.get("verify", "")).strip(),
        "rollback": str(tool_args.get("rollback", "")).strip(),
        "overwrite_existing": overwrite_existing,
        "host_notes": host_notes,
    }


def _tool_metadata_brief(meta):
    if not meta:
        return ""
    parts = [meta["sensitivity"], "state-change" if meta["changes_state"] else "read-only"]
    if meta["overwrite_existing"]:
        parts.append("overwrite")
    return ", ".join(parts)


def _is_dangerous(tool_name, tool_args):
    """Local safeguard for clearly dangerous operations"""
    if tool_name == "execute_command":
        cmd = str(tool_args.get("command", ""))
        return any(r.search(cmd) for r in DANGEROUS_REGEXES)
    if tool_name in ("patch_file", "write_file"):
        # Normalize path to prevent ../ bypass
        path = _safe_realpath(tool_args.get("path", ""))
        if any(path.startswith(p) for p in DANGEROUS_PATHS):
            return True
        home = os.path.expanduser("~")
        rel = os.path.relpath(path, home)
        return not rel.startswith("..") and any(rel.startswith(p) for p in DANGEROUS_HOME_PATHS)
    return False


def confirm_action(tool_name, tool_args, auto_yes, confirm_default="y", force_yes=False, meta=None):
    forced = _is_dangerous(tool_name, tool_args)
    if meta is None:
        meta = _tool_metadata(tool_name, tool_args)
    sensitivity = meta["sensitivity"]
    # --force skips all confirmations except locally forced dangerous patterns
    if force_yes and not forced:
        return True
    if auto_yes and sensitivity != "high" and not forced:
        return True
    if sensitivity != "high" and not forced:
        return True

    desc = _format_tool_args(tool_name, tool_args, meta)

    default_yes = confirm_default.lower() in ("y", "yes")
    hint = "[Y/n]" if default_yes else "[y/N]"
    print(f"\n\033[33m⚠ High-risk operation: {desc}\033[0m")
    print(f"  Sensitivity: {meta['sensitivity']}")
    print(f"  State change: {'yes' if meta['changes_state'] else 'no'}")
    for note in meta["host_notes"]:
        print(f"  Note: {note}")
    if tool_name == "patch_file":
        preview = _patch_preview(tool_args.get("path", ""), tool_args.get("edits", []))
        if "error" in preview:
            print(f"  Patch preview: unavailable ({preview['error']})")
        elif preview.get("preview"):
            print("  Patch preview:")
            print(_indent_block(preview["preview"]))
    if meta["reason"]:
        print(f"  Reason: {meta['reason']}")
    if meta["verify"]:
        print(f"  Verify: {meta['verify']}")
    if meta["rollback"]:
        print(f"  Rollback: {meta['rollback']}")
    if forced:
        print("  Local safeguard: forced confirmation for this action pattern")
    answer = input(f"Confirm? {hint} ").strip().lower()
    if not answer:
        return default_yes
    return answer in ("y", "yes")


