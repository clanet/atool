_CONFIG_KEYS = ("api_url", "api_key", "model", "proxy", "auth_type", "confirm_default", "max_tokens", "language", "interactive")

def load_config(args):
    """Merge config file, env vars, CLI args. Priority: CLI > env > config file > defaults"""
    # Determine provider first
    provider = "openai"
    file_config = {}

    conf_path = CONF_PATH
    if os.path.exists(conf_path):
        # Check config file ownership to prevent tampering
        if not _is_owner(conf_path):
            print("\033[31mWarning: config file has unexpected owner, ignored\033[0m")
        else:
            cp = configparser.ConfigParser()
            cp.read(conf_path)
            if cp.has_section("default"):
                for key in ("provider",) + _CONFIG_KEYS:
                    if cp.has_option("default", key):
                        file_config[key] = cp.get("default", key)

    if "provider" in file_config:
        provider = file_config["provider"]
    if os.environ.get("ATOOL_PROVIDER"):
        provider = os.environ["ATOOL_PROVIDER"]
    if args.provider:
        provider = args.provider

    if provider not in PROVIDER_DEFAULTS:
        print(f"\033[31mError: unsupported provider: {provider}, available: openai, claude, codex\033[0m")
        sys.exit(1)

    # Start from provider defaults
    defaults = PROVIDER_DEFAULTS[provider]
    config = {"provider": provider, "api_url": defaults["api_url"], "api_key": "", "model": defaults["model"],
              "proxy": "", "auth_type": "key", "confirm_default": "y"}

    # Config file
    for key in _CONFIG_KEYS:
        if key in file_config:
            config[key] = file_config[key]
    # Compat: old config auth_type=api_key
    if config["auth_type"] not in ("key", "oauth"):
        config["auth_type"] = "key"

    # Env vars (different var names per provider)
    if provider == "claude":
        env_map = [("ANTHROPIC_API_URL", "api_url"), ("ANTHROPIC_API_KEY", "api_key"), ("ANTHROPIC_MODEL", "model")]
    else:
        env_map = [("OPENAI_API_BASE", "api_url"), ("OPENAI_API_KEY", "api_key"), ("OPENAI_MODEL", "model")]

    for env_name, key in env_map:
        val = os.environ.get(env_name)
        if val:
            config[key] = val

    # Proxy: env vars
    for env_name in ("ATOOL_PROXY", "HTTPS_PROXY", "HTTP_PROXY", "ALL_PROXY"):
        val = os.environ.get(env_name) or os.environ.get(env_name.lower())
        if val:
            config["proxy"] = val
            break

    # CLI args (highest priority)
    if args.api_url:
        config["api_url"] = args.api_url
    if args.api_key:
        config["api_key"] = args.api_key
    if args.model:
        config["model"] = args.model
    if args.proxy:
        config["proxy"] = args.proxy

    # OAuth: dynamically load token from CLI credential files
    if config["auth_type"] == "oauth" and not config["api_key"]:
        token = _load_oauth_token(config["provider"])
        if token:
            config["api_key"] = token

    return config


