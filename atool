# Local override: force confirmation on these patterns regardless of model's risk_level
DANGEROUS_REGEXES = [re.compile(p) for p in [
    r'\brm\s+.*(-[rf]|--recursive|--force)', r'\brmdir\b', r'\bmkfs\b', r'\bfdisk\b', r'\bdd\s+if=',
    r'\breboot\b', r'\bshutdown\b', r'\bpoweroff\b', r'\bhalt\b',
    r'\bsystemctl\s+(stop|disable)\b', r'\bservice\s+\S+\s+stop\b',
    r'\bkill\b', r'\bkillall\b', r'\bpkill\b',
    r'>\s*/dev/', r'\bchmod\s+777\b', r'\bchown\b',
]]
DANGEROUS_PATHS = ["/etc/", "/boot/", "/usr/", "/var/", "/sys/", "/proc/", "/root/", "/lib/", "/lib64/", "/bin/", "/sbin/"]
DANGEROUS_HOME_PATHS = [".ssh/", ".bashrc", ".bash_profile", ".profile", ".zshrc", ".gnupg/"]


def _is_dangerous(tool_name, tool_args):
    """Local keyword matching to detect dangerous operations"""
    if tool_name == "execute_command":
        cmd = str(tool_args.get("command", ""))
        return any(r.search(cmd) for r in DANGEROUS_REGEXES)
    if tool_name == "write_file":
        # Normalize path to prevent ../ bypass
        path = os.path.realpath(os.path.expanduser(tool_args.get("path", "")))
        if any(path.startswith(p) for p in DANGEROUS_PATHS):
            return True
        home = os.path.expanduser("~")
        rel = os.path.relpath(path, home)
        return not rel.startswith("..") and any(rel.startswith(p) for p in DANGEROUS_HOME_PATHS)
    return False


def confirm_action(tool_name, tool_args, auto_yes, confirm_default="y"):
    forced = _is_dangerous(tool_name, tool_args)
    risk = tool_args.get("risk_level", "low")
    if auto_yes and not forced:
        return True
    if risk != "high" and not forced:
        return True

    if tool_name == "execute_command":
        desc = f"Execute command: {tool_args['command']}"
    elif tool_name == "write_file":
        desc = f"Write file: {tool_args['path']}"
    else:
        desc = f"{tool_name}: {json.dumps(tool_args, ensure_ascii=False)}"

    default_yes = confirm_default.lower() in ("y", "yes")
    hint = "[Y/n]" if default_yes else "[y/N]"
    print(f"\n\033[33m⚠ High-risk operation: {desc}\033[0m")
    answer = input(f"Confirm? {hint} ").strip().lower()
    if not answer:
        return default_yes
    return answer in ("y", "yes")


# ============================================================
# Context compaction
# ============================================================

def _compact_context(state, provider):
    """Trim old messages when context is too long, keep system prompt and recent conversation"""
    raw = json.dumps(state, ensure_ascii=False)
    if len(raw) <= MAX_CONTEXT_CHARS:
        return

    if provider == "claude":
        msgs = state["messages"]
    else:
        # OpenAI/Codex: state[0] is the system message, skip it
        msgs = state[1:]

    if len(msgs) <= 4:
        return

    # Keep roughly half the limit worth of messages from the end
    target = MAX_CONTEXT_CHARS // 2
    kept_size = 0
    cut = len(msgs)
    while cut > 1:
        cut -= 1
        kept_size += len(json.dumps(msgs[cut], ensure_ascii=False))
        if kept_size >= target:
            break

    # Adjust forward to a clean cut point (user message, not tool_result) to avoid breaking pairs
    while cut < len(msgs) - 1:
        msg = msgs[cut]
        if msg["role"] == "user" and isinstance(msg.get("content"), str):
            break
        cut += 1
    else:
        # No valid cut point found, skip compaction
        return

    if cut <= 1:
        return

    # Insert compaction notice, maintain user/assistant alternation
    notice = [
        {"role": "user", "content": "[System notice: earlier conversation has been compacted to save context space]"},
        {"role": "assistant", "content": "Understood, the earlier conversation has been compacted. Please continue."},
    ]
    removed = cut
    if provider == "claude":
        state["messages"] = notice + msgs[cut:]
    else:
        state[1:] = notice + msgs[cut:]
    print(f"\033[33mContext compacted (removed {removed} earlier messages)\033[0m")


# ============================================================
# Context persistence
# ============================================================

def _save_context(state, provider):
    """Save current context to file"""
    try:
        os.makedirs(ATOOL_DIR, exist_ok=True, mode=0o700)
        with open(CONTEXT_PATH, "w") as f:
            json.dump({"provider": provider, "state": state}, f, ensure_ascii=False)
        _secure_chmod(CONTEXT_PATH, 0o600)
    except Exception:
        pass


def _load_context(provider):
    """Load previous context, return None if provider mismatch or invalid structure"""
    try:
        if not os.path.exists(CONTEXT_PATH):
            return None
        if os.path.getsize(CONTEXT_PATH) > 1024 * 1024:
            print("\033[33mContext file too large (>1MB), starting new conversation\033[0m")
            return None
        with open(CONTEXT_PATH) as f:
            data = json.load(f)
        if data.get("provider") != provider:
            return None
        state = data["state"]
        # Basic structure validation
        if provider == "claude":
            if not isinstance(state, dict) or "messages" not in state:
                return None
        else:
            if not isinstance(state, list) or len(state) < 2:
                return None
            # Validate message format: first message must be system
            if not isinstance(state[0], dict) or state[0].get("role") != "system":
                return None
        return state
    except Exception:
        return None


# ============================================================
# Main loop
# ============================================================

def _format_tool_args(name, args):
    if name == "execute_command":
        return args["command"]
    if name in ("read_file", "write_file", "read_image"):
        return args["path"]
    return json.dumps(args, ensure_ascii=False)


def _print_result(name, result):
    if name == "execute_command":
        if result["stdout"]:
            print(result["stdout"], end="")
        if result["stderr"]:
            print(f"\033[31m{result['stderr']}\033[0m", end="")
        if result["returncode"] != 0:
            print(f"\033[31m  Exit code: {result['returncode']}\033[0m")
    elif name == "read_file":
        if "error" in result:
            print(f"\033[31m  Error: {result['error']}\033[0m")
        else:
            lines = result["content"].splitlines()
            preview = "\n".join(lines[:10])
            if len(lines) > 10:
                preview += f"\n... ({len(lines)} lines total)"
            print(preview)
    elif name == "write_file":
        if "error" in result:
            print(f"\033[31m  Error: {result['error']}\033[0m")
        else:
            print("  Write successful")
    elif name == "read_image":
        if "error" in result:
            print(f"\033[31m  Error: {result['error']}\033[0m")


def main_loop(task, config, auto_yes, continue_ctx=False):
    p = PROVIDERS[config["provider"]]
    provider = config["provider"]

    if continue_ctx:
        state = _load_context(provider)
        if state:
            print("\033[36mContinuing previous conversation\033[0m")
            # Append new task as user message
            if provider == "claude":
                state["messages"].append({"role": "user", "content": task})
            elif provider in ("openai", "codex"):
                state.append({"role": "user", "content": task})
        else:
            print("\033[33mNo previous context found, starting new conversation\033[0m")
            state = p["init"](_build_system_prompt(config.get("language")), task)
    else:
        state = p["init"](_build_system_prompt(config.get("language")), task)

    iterations = 0
    while True:
        iterations += 1
        if iterations > MAX_ITERATIONS:
            print("\033[33mMax iteration limit reached, stopping\033[0m")
            _save_context(state, provider)
            break

        _compact_context(state, provider)

        try:
            parsed = p["request"](state, config)
        except urllib.error.HTTPError as e:
            try:
                body = e.read().decode()
            except Exception:
                body = ""
            print(f"\033[31mAPI request failed ({e.code}): {body[:200]}\033[0m")
            return
        except urllib.error.URLError as e:
            print(f"\033[31mCannot connect to API: {e.reason}\033[0m")
            return
        except Exception as e:
            print(f"\033[31mAPI call error: {e}\033[0m")
            return

        if parsed["content"]:
            print(f"\n{parsed['content']}")

        if not parsed["tool_calls"]:
            _save_context(state, provider)
            break

        for tc in parsed["tool_calls"]:
            try:
                name, args = tc["name"], tc["args"]
                # Tool call that failed at parse stage
                if name == "__parse_error__":
                    result_str = json.dumps({"error": tc["_error"]}, ensure_ascii=False)
                    print(f"\n\033[31m{tc['_error']}\033[0m")
                    p["add_tool_result"](state, tc["id"], result_str)
                    continue

                print(f"\n\033[36m→ {name}: {_format_tool_args(name, args)}\033[0m")

                if name not in TOOL_HANDLERS:
                    result_str = json.dumps({"error": f"Unknown tool: {name}"}, ensure_ascii=False)
                    print(f"\033[31m  Unknown tool: {name}\033[0m")
                elif confirm_action(name, args, auto_yes, config.get("confirm_default", "y")):
                    result = TOOL_HANDLERS[name](args)
                    if isinstance(result, dict) and result.get("_image") and "error" not in result:
                        print(f"  \033[32mImage loaded ({len(result['data']) * 3 // 4 // 1024}KB)\033[0m")
                        p["add_tool_result"](state, tc["id"], result)
                        continue
                    _print_result(name, result)
                    result_str = json.dumps(_truncate_result(result), ensure_ascii=False)
                else:
                    result_str = json.dumps({"skipped": "User declined execution"}, ensure_ascii=False)
                    print("\033[33m  Skipped\033[0m")
            except Exception as e:
                result_str = json.dumps({"error": f"Tool execution error: {e}"}, ensure_ascii=False)
                print(f"\033[31m  Tool execution error: {e}\033[0m")

            p["add_tool_result"](state, tc["id"], result_str)

        _save_context(state, provider)


# ============================================================
# Setup wizard
# ============================================================

def _prompt_choice(prompt, choices):
    """Let user choose from a list, return selected item"""
    for i, c in enumerate(choices, 1):
        print(f"  {i}. {c}")
    while True:
        answer = input(prompt).strip()
        if answer.isdigit() and 1 <= int(answer) <= len(choices):
            return choices[int(answer) - 1]
        print("\033[31m  Invalid input, please try again\033[0m")


def setup_wizard(config):
    """First-time setup wizard, writes to ~/.atool/config.ini"""
    print("\033[36mFirst time setup — please configure your API connection:\033[0m\n")

    # Choose provider
    provider = _prompt_choice("Choose provider [1-3]: ", ["openai", "claude", "codex"])
    defaults = PROVIDER_DEFAULTS[provider]
    auth_type = "key"
    url = ""
    key = ""

    # claude/codex support OAuth
    if provider in ("claude", "codex"):
        auth_type = _prompt_choice("Auth method [1-2]: ", ["oauth", "key"])

    if auth_type == "oauth":
        token = _load_oauth_token(provider)
        if token:
            cred_hint = "~/.claude/.credentials.json" if provider == "claude" else "~/.codex/auth.json"
            print(f"\033[32m  OAuth token loaded from {cred_hint}\033[0m")
            key = token
        else:
            if provider == "claude":
                print("\033[31m  ~/.claude/.credentials.json not found\033[0m")
                print("  Please install and log in to Claude Code first: claude login")
            else:
                print("\033[31m  ~/.codex/auth.json not found\033[0m")
                print("  Please install and log in to Codex CLI first: codex login")
            sys.exit(1)
        url = defaults["api_url"]
    else:
        # Manual API Key input
        default_url = defaults["api_url"]
        url = input(f"API URL (press Enter for default {default_url}): ").strip() or default_url
        while True:
            key = input("API Key: ").strip()
            if key:
                break
            print("\033[31m  API Key cannot be empty\033[0m")

    # Model
    default_model = defaults["model"]
    if provider in ("openai", "codex") and auth_type != "oauth":
        models = ["gpt-5.4"]
        print("Choose model:")
        for i, m in enumerate(models, 1):
            print(f"  {i}. {m}")
        print(f"  {len(models) + 1}. Custom")
        answer = input(f"Choose [1-{len(models) + 1}] (press Enter for {default_model}): ").strip()
        if not answer:
            model = default_model
        elif answer.isdigit() and 1 <= int(answer) <= len(models):
            model = models[int(answer) - 1]
        else:
            model = input("Enter model name: ").strip() or default_model
    else:
        model = input(f"Model (press Enter for default {default_model}): ").strip() or default_model

    # Proxy (optional)
    proxy = input("Proxy address (press Enter to skip, e.g. socks5://127.0.0.1:1080): ").strip()

    # Write config file
    os.makedirs(ATOOL_DIR, exist_ok=True, mode=0o700)
    conf_path = CONF_PATH
    cp = configparser.ConfigParser()
    if os.path.exists(conf_path):
        cp.read(conf_path)
    if not cp.has_section("default"):
        cp.add_section("default")
    cp.set("default", "provider", provider)
    cp.set("default", "auth_type", auth_type)
    cp.set("default", "api_url", url)
    cp.set("default", "model", model)
    if auth_type != "oauth":
        cp.set("default", "api_key", key)
    if proxy:
        cp.set("default", "proxy", proxy)

    with open(conf_path, "w") as f:
        cp.write(f)
    _secure_chmod(conf_path, 0o600)

    print(f"\n\033[32mConfig saved to {conf_path}\033[0m\n")


# ============================================================
# CLI entry point
# ============================================================

def main():
    parser = argparse.ArgumentParser(description="AI ops tool")
    parser.add_argument("task", nargs="*", help="Task description for the ops operation")
    parser.add_argument("-y", "--yes", action="store_true", help="Skip all confirmations")
    parser.add_argument("-c", "--continue", dest="continue_ctx", action="store_true", help="Continue previous conversation")
    parser.add_argument("-p", "--provider", choices=["openai", "claude", "codex"], help="API provider")
    parser.add_argument("--api-url", help="API URL")
    parser.add_argument("--api-key", help="API Key (prefer env var or config file, CLI args are visible in process list)")
    parser.add_argument("--model", help="Model name")
    parser.add_argument("--proxy", help="Proxy address (http/https/socks5)")
    parser.add_argument("-i", "--interactive", action="store_true", help="Interactive continuous mode")
    args = parser.parse_args()

    config = load_config(args)

    if not config["api_key"]:
        setup_wizard(config)
        config = load_config(args)

    interactive = args.interactive or config.get("interactive") in ("true", "1", "yes")
    _init_proxy(config.get("proxy"))
    task = " ".join(args.task) if args.task else ""

    if interactive:
        continue_ctx = args.continue_ctx
        # Run initial task from CLI args if provided
        if task:
            main_loop(task, config, args.yes, continue_ctx)
            continue_ctx = True
        # Interactive input loop
        print("\033[36mInteractive mode (type 'quit' to exit)\033[0m")
        while True:
            try:
                task = input("\033[36m> \033[0m").strip()
            except (KeyboardInterrupt, EOFError):
                print()
                break
            if not task:
                continue
            if task.lower() in ("quit", "exit", "q"):
                break
            main_loop(task, config, args.yes, continue_ctx)
            continue_ctx = True
    else:
        if not task:
            if sys.stdin.isatty():
                task = input("Enter task: ").strip()
            else:
                print("\033[31mError: please specify task via arguments in non-interactive mode\033[0m")
                sys.exit(1)
        if not task:
            print("\033[31mError: task cannot be empty\033[0m")
            sys.exit(1)
        main_loop(task, config, args.yes, args.continue_ctx)


if __name__ == "__main__":
    if IS_WINDOWS:
        os.system("")  # Enable Windows 10+ ANSI support
    try:
        main()
    except (KeyboardInterrupt, EOFError):
        print()
        sys.exit(130)
        sys.exit(130)
