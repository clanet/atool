def _is_owner(path):
    """Check if the current user owns the file (always True on Windows)"""
    return IS_WINDOWS or os.stat(path).st_uid == os.getuid()

def _secure_chmod(path, mode):
    """Set file permissions (no-op on Windows)"""
    if not IS_WINDOWS:
        os.chmod(path, mode)

