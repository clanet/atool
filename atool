def _safe_int(val, default):
    """Safely convert to int, return default on failure"""
    try:
        return int(val) if val else default
    except (ValueError, TypeError):
        return default


def _claude_tools():
    return [{"name": t["function"]["name"], "description": t["function"]["description"],
             "input_schema": t["function"]["parameters"]} for t in TOOLS]


def _claude_init(system, task):
    return {"system": system, "messages": [{"role": "user", "content": task}]}


def _claude_request(state, config):
    base = config["api_url"].rstrip("/")
    url = base if base.endswith("/messages") else base + "/messages"
    data = _http_post(url, _anthropic_headers(config["api_key"], config.get("auth_type", "key")),
                      {"model": config["model"], "max_tokens": _safe_int(config.get("max_tokens"), 8192),
                       "system": state["system"], "messages": state["messages"],
                       "tools": _claude_tools(), "stream": False})

    if data.get("type") == "error":
        raise RuntimeError(f"API error: {data.get('error', {}).get('message', data)}")
    if "content" not in data:
        raise RuntimeError(f"Unexpected API response format: {json.dumps(data, ensure_ascii=False)[:200]}")

    state["messages"].append({"role": "assistant", "content": data["content"]})

    content = None
    tool_calls = []
    for block in data["content"]:
        if block["type"] == "text":
            content = (content or "") + block["text"]
        elif block["type"] == "tool_use":
            tool_calls.append({"id": block["id"], "name": block["name"], "args": block["input"]})
    stop_reason = data.get("stop_reason")
    if stop_reason == "max_tokens":
        print("\033[33mWarning: model output truncated (token limit reached)\033[0m")
    return {"content": content, "tool_calls": tool_calls}


def _claude_add_tool_result(state, call_id, result):
    if isinstance(result, dict) and result.get("_image"):
        content = [{"type": "image", "source": {"type": "base64",
                    "media_type": result["media_type"], "data": result["data"]}}]
    else:
        content = result
    result_block = {"type": "tool_result", "tool_use_id": call_id, "content": content}
    msgs = state["messages"]
    # Merge multiple tool_results into the same user message
    if msgs and msgs[-1]["role"] == "user" and isinstance(msgs[-1]["content"], list):
        msgs[-1]["content"].append(result_block)
    else:
        msgs.append({"role": "user", "content": [result_block]})


